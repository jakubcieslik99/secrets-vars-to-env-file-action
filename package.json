{
  "name": "secrets-vars-to-env-file-action",
  "version": "1.6.0",
  "description": "Export GitHub secrets & vars to environment variables & specified file",
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest --testPathIgnorePatterns test/e2e --watchAll",
    "test:e2e": "node --experimental-vm-modules node_modules/jest/bin/jest --testPathPatterns='test/e2e/.*\\.test\\.ts'",
    "build": "tsc",
    "package": "ncc build --source-map --license licenses.txt",
    "prepare:release": "rimraf build && pnpm run build && pnpm run package",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --ignore-path .gitignore --write \"**/*.+(js|ts)\"",
    "update:all": "corepack up && pnpm update"
  },
  "author": "Jakub Cieślik",
  "license": "MIT",
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "dependencies": {
    "@actions/core": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
